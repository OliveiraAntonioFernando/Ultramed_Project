# Copie para .env e preencha. Nunca commite o .env.

# Django
DJANGO_SECRET_KEY=gere-uma-chave-longa-e-aleatoria
DJANGO_ALLOWED_HOSTS=ultramedsaudexingu.com.br,www.ultramedsaudexingu.com.br
DEBUG=False

# MariaDB (container db — só altere senha se souber recriar/migrar o volume)
MARIADB_ROOT_PASSWORD=
MARIADB_DATABASE=ultramed_db
MARIADB_USER=ultramed_user
MARIADB_PASSWORD=

SQL_ENGINE=django.db.backends.mysql
SQL_DATABASE=ultramed_db
SQL_USER=ultramed_user
SQL_PASSWORD=
SQL_HOST=db
SQL_PORT=3306
SQL_ROOT_PASSWORD=

# Mercado Pago — PRODUÇÃO (APP_USR-... / chave pública de produção)
MERCADO_PAGO_PUBLIC_KEY=
MERCADO_PAGO_ACCESS_TOKEN=
